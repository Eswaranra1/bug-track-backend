# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Email — Resend (https://resend.com). Get API key, optionally verify domain for custom "from".
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=BugTrack <onboarding@resend.dev>
# Optional: recipient for GET /api/auth/test-email
RESEND_TEST_TO=your@email.com

# Frontend URL (used in password reset email links)
CLIENT_URL=http://localhost:5173
